# Python
__pycache__/
*.py[cod]

# Image Mode Studio runtime artifacts
.studio.pid
studio.log
studio.log.err
.buildkitd.toml

# Build output (RAW/qcow2 images can be multi-GB)
output/
bootc-output/

# Harvested RPM cache (pulled via your own Red Hat entitlement — not ours to
# redistribute via git)
rpm-cache/

# Auxiliary non-standard RPMs installed into the image (keep the dir only)
aux-rpms/*.rpm
